{
  "entities": {
    "RepairRecord": {
      "title": "Repair Record",
      "description": "Stores details about a vehicle repair.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the repair record." },
        "userId": { "type": "string", "description": "The ID of the user who owns this record (anonymous)." },
        "vehicleInfo": {
          "type": "object",
          "properties": {
            "make": { "type": "string" },
            "model": { "type": "string" },
            "year": { "type": "integer" }
          }
        },
        "issueDescription": { "type": "string", "description": "Description of the vehicle's problem." },
        "aiDiagnosis": { "type": "string", "description": "The AI-generated diagnosis." },
        "status": { "type": "string", "enum": ["pending", "diagnosed", "repaired"], "description": "Current status of the repair." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "issueDescription"]
    },
    "Order": {
      "title": "Partner Order",
      "description": "Stores a part request from a partner.",
      "type": "object",
      "properties": {
        "partnerEmail": { "type": "string" },
        "partnerUid": { "type": "string" },
        "partName": { "type": "string" },
        "amazonUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_review", "approved", "shipped", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "btcAddress": { "type": "string" }
      },
      "required": ["partnerUid", "partName", "amazonUrl", "status"]
    }
  },
  "firestore": {
    "/repairs/{repairId}": {
      "schema": "RepairRecord",
      "description": "Repair record document."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Partner part orders."
    }
  }
}
